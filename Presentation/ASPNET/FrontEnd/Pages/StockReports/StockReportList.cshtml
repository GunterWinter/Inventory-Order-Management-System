@page
@{
    ViewData["Title"] = "Stock Report List";
}

<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info">
                This report shows only batches that still have stock on hand. Use it to check which product is available in which batch and how much quantity remains in the warehouse.
            </div>
            <div class="grid-container">
                <div id="MainGrid" ref="mainGridRef"></div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/StockReports/StockReportList.cshtml.js"></script>
}
