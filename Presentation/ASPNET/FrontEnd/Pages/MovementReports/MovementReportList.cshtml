@page
@{
    ViewData["Title"] = "Batch Profit Report";
}

<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info">
                This page only shows batches that have already been sold. Each row represents the actual profit by product and batch based on issued allocations.
            </div>
            <div class="grid-container">
                <div id="MainGrid" ref="mainGridRef"></div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/MovementReports/MovementReportList.cshtml.js"></script>
}
